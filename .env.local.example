# ─── Supabase (obligatoire) ──────────────────────────────────────────────────
# Dashboard Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=        # https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # clé publique (anon)
SUPABASE_SERVICE_ROLE_KEY=       # clé service role (serveur uniquement, JAMAIS exposée au client)

# ─── Prisma / Postgres (obligatoire) ─────────────────────────────────────────
# Dashboard Supabase → Project Settings → Database → Connection string
DATABASE_URL=    # Transaction Pooler (port 6543) — runtime applicatif
DIRECT_URL=      # Direct connection (port 5432) — migrations `prisma db push`

# ─── Gemini (obligatoire — coach Kaba) ───────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Resend (recommandé — emails transactionnels) ────────────────────────────
# https://resend.com/api-keys — si absent, les emails passent en mode mock (log console)
RESEND_API_KEY=
RESEND_FROM_EMAIL=   # ex: "StartKaba <kaba@startkaba.com>" — sans domaine custom: "StartKaba <onboarding@resend.dev>"

# ─── App (obligatoire) ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=   # En prod: l'URL Vercel finale, ex https://startkaba.vercel.app — sert au callback OAuth et aux liens email

# ─── Sentry (optionnel — capture d'erreurs) ──────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ─── Dev local uniquement ────────────────────────────────────────────────────
# DEV_BYPASS_AUTH=true   # contourne l'auth Supabase en local — NE JAMAIS activer en prod

# ─── Stripe (Phase 2 — paiement réel, non branché) ───────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Fedapay (Phase 2 — Mobile Money UEMOA, non branché) ─────────────────────
FEDAPAY_SECRET_KEY=
FEDAPAY_PUBLIC_KEY=
