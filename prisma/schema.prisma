generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  id                 String             @id @default(uuid())
  email              String             @unique
  fullName           String
  avatarUrl          String?
  city               City               @default(OTHER)
  bio                String?
  projectName        String?
  projectDescription String?
  skills             String[]
  currentLevelId     Int                @default(1)
  totalXp            Int                @default(0)
  subscriptionStatus SubscriptionStatus @default(FREE)
  isAdmin                Boolean                 @default(false)
  role                   UserRole                @default(ENTREPRENEUR)
  payoutInfo             Json?
  coachApplicationStatus CoachApplicationStatus?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  progress       UserProgress[]
  earnedBadges   UserBadge[]
  coachMessages  CoachMessage[]
  notifications  Notification[]
  reflections    TaskReflection[]
  microInputs    UserMicroInput[]
  levelAnalyses  LevelAnalysis[]
  products       Product[]       @relation("CoachProducts")
  purchases      Purchase[]
  payouts        Payout[]

  @@map("user_profiles")
}

enum City {
  COTONOU
  ABIDJAN
  DAKAR
  LOME
  BAMAKO
  OTHER
}

enum SubscriptionStatus {
  FREE
  PREMIUM
}

enum UserRole {
  ENTREPRENEUR
  COACH
  ADMIN
}

enum CoachApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model UserProgress {
  id          String         @id @default(uuid())
  userId      String
  taskId      Int
  levelId     Int
  status      ProgressStatus @default(NOT_STARTED)
  quizScore   Int?
  completedAt DateTime?
  xpEarned    Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user UserProfile @relation(fields: [userId], references: [id])

  @@unique([userId, taskId])
  @@map("user_progress")
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  badgeId  Int
  earnedAt DateTime @default(now())

  user UserProfile @relation(fields: [userId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model CoachMessage {
  id        String      @id @default(uuid())
  userId    String
  levelId   Int
  role      MessageRole
  content   String      @db.Text
  createdAt DateTime    @default(now())

  user UserProfile @relation(fields: [userId], references: [id])

  @@map("coach_messages")
}

enum MessageRole {
  USER
  ASSISTANT
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user UserProfile @relation(fields: [userId], references: [id])

  @@map("notifications")
}

enum NotificationType {
  BADGE_EARNED
  LEVEL_UNLOCKED
  TASK_COMPLETED
  MESSAGE_RECEIVED
  SYSTEM
}

model TaskReflection {
  id             String   @id @default(uuid())
  userId         String
  taskId         Int
  levelId        Int
  exerciseIndex  Int
  answer         String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user UserProfile @relation(fields: [userId], references: [id])

  @@unique([userId, taskId, exerciseIndex])
  @@map("task_reflections")
}

model UserMicroInput {
  id         String   @id @default(uuid())
  userId     String
  taskId     Int
  storageKey String
  value      String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user UserProfile @relation(fields: [userId], references: [id])

  @@unique([userId, taskId, storageKey])
  @@map("user_micro_inputs")
}

// ─── Marketplace ──────────────────────────────────────────────────────────────

enum ProductCategory {
  TEMPLATE_GRATUIT
  FORMATION_NIVEAU
  FORMATION_COACH
}

enum OwnerType {
  STARTKABA
  COACH
}

enum ProductStatus {
  DRAFT
  PUBLISHED
}

enum PaymentStatus {
  PENDING
  PAID
  MOCK_PAID
}

enum PayoutStatus {
  PENDING
  PAID
}

model Product {
  id             String          @id @default(uuid())
  ownerType      OwnerType
  coachId        String?
  title          String
  description    String          @db.Text
  category       ProductCategory
  priceCFA       Int             @default(0)
  levelTag       Int?
  fileUrl        String
  coverImageUrl  String?
  status         ProductStatus   @default(DRAFT)
  downloadsCount Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  coach     UserProfile? @relation("CoachProducts", fields: [coachId], references: [id])
  purchases Purchase[]

  @@map("products")
}

model Purchase {
  id             String        @id @default(uuid())
  userId         String
  productId      String
  priceCFA       Int
  commissionCFA  Int           @default(0)
  coachAmountCFA Int           @default(0)
  paymentStatus  PaymentStatus @default(PENDING)
  paidAt         DateTime?
  createdAt      DateTime      @default(now())

  user    UserProfile @relation(fields: [userId], references: [id])
  product Product     @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("purchases")
}

model Payout {
  id        String       @id @default(uuid())
  coachId   String
  amountCFA Int
  period    String
  status    PayoutStatus @default(PENDING)
  paidAt    DateTime?
  createdAt DateTime     @default(now())

  coach UserProfile @relation(fields: [coachId], references: [id])

  @@map("payouts")
}

model LevelAnalysis {
  id        String   @id @default(uuid())
  userId    String
  levelId   Int
  content   String   @db.Text
  createdAt DateTime @default(now())

  user UserProfile @relation(fields: [userId], references: [id])

  @@unique([userId, levelId])
  @@map("level_analyses")
}
