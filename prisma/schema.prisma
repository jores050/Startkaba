generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  id                 String             @id @default(uuid())
  email              String             @unique
  fullName           String
  avatarUrl          String?
  city               City               @default(OTHER)
  bio                String?
  projectName        String?
  projectDescription String?
  skills             String[]
  currentLevelId     Int                @default(1)
  totalXp            Int                @default(0)
  subscriptionStatus SubscriptionStatus @default(FREE)
  isAdmin                Boolean                 @default(false)
  role                   UserRole                @default(ENTREPRENEUR)
  payoutInfo             Json?
  coachApplicationStatus CoachApplicationStatus?
  isOpenToCofounder      Boolean                 @default(false)
  lookingFor             String[]
  publicBio              String?
  showcaseOptIn          Boolean                 @default(false)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  progress            UserProgress[]
  earnedBadges        UserBadge[]
  missionDeliverables MissionDeliverable[]
  kabaReviews         LevelKabaReview[]
  coachMessages       CoachMessage[]
  notifications       Notification[]
  reflections         TaskReflection[]
  microInputs         UserMicroInput[]
  levelAnalyses       LevelAnalysis[]
  products            Product[]            @relation("CoachProducts")
  purchases           Purchase[]
  payouts             Payout[]
  sentConnections      ConnectionRequest[]   @relation("SentConnections")
  receivedConnections  ConnectionRequest[]   @relation("ReceivedConnections")
  groupPosts           GroupPost[]
  groupReplies         GroupReply[]
  helpRequests         HelpRequest[]
  helpReplies          HelpReply[]
  accountabilityAsA    AccountabilityPair[]  @relation("PairUserA")
  accountabilityAsB    AccountabilityPair[]  @relation("PairUserB")

  @@map("user_profiles")
}

enum City {
  COTONOU
  ABIDJAN
  DAKAR
  LOME
  BAMAKO
  OTHER
}

enum SubscriptionStatus {
  FREE
  PREMIUM
}

enum UserRole {
  ENTREPRENEUR
  COACH
  ADMIN
}

enum CoachApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model UserProgress {
  id                 String          @id @default(uuid())
  userId             String
  taskId             Int
  levelId            Int
  status             ProgressStatus  @default(NOT_STARTED)
  quizScore          Int?
  completedAt        DateTime?
  xpEarned           Int             @default(0)
  missionStatus      MissionStatus?
  missionStartedAt   DateTime?
  missionCompletedAt DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  user UserProfile @relation(fields: [userId], references: [id])

  @@unique([userId, taskId])
  @@map("user_progress")
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum MissionStatus {
  LEARNING
  MISSION_IN_PROGRESS
  CAPTURING
  COMPLETED
}

model MissionDeliverable {
  id        String      @id @default(uuid())
  userId    String
  taskId    Int
  type      String
  content   String      @db.Text
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user UserProfile @relation(fields: [userId], references: [id])

  @@unique([userId, taskId, type])
  @@map("mission_deliverables")
}

model LevelKabaReview {
  id            String   @id @default(uuid())
  userId        String
  levelNumber   Int
  verdictGlobal String   @db.Text
  score         String   // excellent | solide_avec_ajustements | à_retravailler | à_recommencer
  forces        Json     // string[]
  ajustements   Json     // { card, probleme, lecon_citee, reformulation_possible }[]
  proverbe      String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user UserProfile @relation(fields: [userId], references: [id])

  @@unique([userId, levelNumber])
  @@index([userId])
  @@map("level_kaba_reviews")
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  badgeId  Int
  earnedAt DateTime @default(now())

  user UserProfile @relation(fields: [userId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model CoachMessage {
  id        String      @id @default(uuid())
  userId    String
  levelId   Int
  role      MessageRole
  content   String      @db.Text
  createdAt DateTime    @default(now())

  user UserProfile @relation(fields: [userId], references: [id])

  @@map("coach_messages")
}

enum MessageRole {
  USER
  ASSISTANT
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user UserProfile @relation(fields: [userId], references: [id])

  @@map("notifications")
}

enum NotificationType {
  BADGE_EARNED
  LEVEL_UNLOCKED
  TASK_COMPLETED
  MESSAGE_RECEIVED
  CONNECTION_REQUEST
  SYSTEM
}

model TaskReflection {
  id             String   @id @default(uuid())
  userId         String
  taskId         Int
  levelId        Int
  exerciseIndex  Int
  answer         String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user UserProfile @relation(fields: [userId], references: [id])

  @@unique([userId, taskId, exerciseIndex])
  @@map("task_reflections")
}

model UserMicroInput {
  id         String   @id @default(uuid())
  userId     String
  taskId     Int
  storageKey String
  value      String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user UserProfile @relation(fields: [userId], references: [id])

  @@unique([userId, taskId, storageKey])
  @@map("user_micro_inputs")
}

// ─── Marketplace ──────────────────────────────────────────────────────────────

enum ProductCategory {
  TEMPLATE_GRATUIT
  FORMATION_NIVEAU
  FORMATION_COACH
}

enum OwnerType {
  STARTKABA
  COACH
}

enum ProductStatus {
  DRAFT
  PUBLISHED
}

enum PaymentStatus {
  PENDING
  PAID
  MOCK_PAID
}

enum PayoutStatus {
  PENDING
  PAID
}

model Product {
  id             String          @id @default(uuid())
  ownerType      OwnerType
  coachId        String?
  title          String
  description    String          @db.Text
  category       ProductCategory
  priceCFA       Int             @default(0)
  levelTag       Int?
  fileUrl        String
  coverImageUrl  String?
  status         ProductStatus   @default(DRAFT)
  downloadsCount Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  coach     UserProfile? @relation("CoachProducts", fields: [coachId], references: [id])
  purchases Purchase[]

  @@map("products")
}

model Purchase {
  id             String        @id @default(uuid())
  userId         String
  productId      String
  priceCFA       Int
  commissionCFA  Int           @default(0)
  coachAmountCFA Int           @default(0)
  paymentStatus  PaymentStatus @default(PENDING)
  paidAt         DateTime?
  createdAt      DateTime      @default(now())

  user    UserProfile @relation(fields: [userId], references: [id])
  product Product     @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("purchases")
}

model Payout {
  id        String       @id @default(uuid())
  coachId   String
  amountCFA Int
  period    String
  status    PayoutStatus @default(PENDING)
  paidAt    DateTime?
  createdAt DateTime     @default(now())

  coach UserProfile @relation(fields: [coachId], references: [id])

  @@map("payouts")
}

model LevelAnalysis {
  id        String   @id @default(uuid())
  userId    String
  levelId   Int
  content   String   @db.Text
  createdAt DateTime @default(now())

  user UserProfile @relation(fields: [userId], references: [id])

  @@unique([userId, levelId])
  @@map("level_analyses")
}

enum MentorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContactMethod {
  WHATSAPP
  EMAIL
  CALENDLY
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Mentor {
  id            String        @id @default(uuid())
  userId        String?
  name          String
  title         String
  expertise     String[]
  bio           String        @db.Text
  avatarUrl     String?
  contactMethod ContactMethod @default(EMAIL)
  contactValue  String
  availability  String
  city          City          @default(OTHER)
  status        MentorStatus  @default(PENDING)
  createdAt     DateTime      @default(now())

  @@map("mentors")
}

model ConnectionRequest {
  id         String           @id @default(uuid())
  fromUserId String
  toUserId   String
  message    String?
  status     ConnectionStatus @default(PENDING)
  createdAt  DateTime         @default(now())

  fromUser UserProfile @relation("SentConnections",     fields: [fromUserId], references: [id])
  toUser   UserProfile @relation("ReceivedConnections", fields: [toUserId],   references: [id])

  @@unique([fromUserId, toUserId])
  @@map("connection_requests")
}

enum GroupType {
  CITY
  LEVEL
}

model Group {
  id           String      @id @default(uuid())
  name         String
  type         GroupType
  cityOrLevel  String
  description  String
  createdAt    DateTime    @default(now())

  posts GroupPost[]

  @@map("groups")
}

model GroupPost {
  id        String       @id @default(uuid())
  groupId   String
  userId    String
  content   String       @db.Text
  createdAt DateTime     @default(now())

  group   Group        @relation(fields: [groupId], references: [id])
  user    UserProfile  @relation(fields: [userId], references: [id])
  replies GroupReply[]

  @@map("group_posts")
}

model GroupReply {
  id        String      @id @default(uuid())
  postId    String
  userId    String
  content   String      @db.Text
  createdAt DateTime    @default(now())

  post GroupPost   @relation(fields: [postId], references: [id])
  user UserProfile @relation(fields: [userId], references: [id])

  @@map("group_replies")
}

enum AccountabilityStatus {
  ACTIVE
  PAUSED
}

model AccountabilityPair {
  id              String               @id @default(uuid())
  userAId         String
  userBId         String
  status          AccountabilityStatus @default(ACTIVE)
  matchedAt       DateTime             @default(now())
  lastCheckInAt   DateTime?

  userA UserProfile @relation("PairUserA", fields: [userAId], references: [id])
  userB UserProfile @relation("PairUserB", fields: [userBId], references: [id])

  @@map("accountability_pairs")
}

enum HelpStatus {
  OPEN
  RESOLVED
}

model HelpRequest {
  id          String      @id @default(uuid())
  userId      String
  title       String
  description String      @db.Text
  levelTag    Int?
  status      HelpStatus  @default(OPEN)
  createdAt   DateTime    @default(now())

  user    UserProfile @relation(fields: [userId], references: [id])
  replies HelpReply[]

  @@map("help_requests")
}

model HelpReply {
  id            String      @id @default(uuid())
  helpRequestId String
  userId        String
  content       String      @db.Text
  createdAt     DateTime    @default(now())

  request HelpRequest @relation(fields: [helpRequestId], references: [id])
  user    UserProfile @relation(fields: [userId], references: [id])

  @@map("help_replies")
}
